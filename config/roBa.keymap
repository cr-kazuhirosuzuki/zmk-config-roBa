
/ {
    macros {
        ShiftClick: ShiftClick {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <1>;
            tap-ms = <1>;
            bindings =
                <&macro_press &kp LSHIFT>,
                <&macro_tap &mkp LCLK>,
                <&macro_release &kp LSHIFT>;
        };

        GuiClick: GuiClick {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <1>;
            tap-ms = <1>;
            bindings =
                <&macro_press &kp LGUI>,
                <&macro_tap &mkp LCLK>,
                <&macro_release &kp LGUI>;
        };

        SelWord_Apple: SelWord_Apple {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&kp LA(LEFT)>,
                <&kp LA(LS(RIGHT))>;
        };
    };

    combos {
        compatible = "zmk,combos";

        caps_word_combo {
            timeout-ms = <30>;
            key-positions = <13 25>;
            bindings = <&caps_word>;
        };

        f1_combo {
            timeout-ms = <30>;
            key-positions = <1 2>;
            bindings = <&kp F1>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        Mouse_Apple {
            bindings = <
                &ShiftClick &GuiClick &SelWord_Apple
            >;
            sensor-bindings = <&mouse_scroll SCRL_UP SCRL_DOWN>;
        };

        Mouse_LinWin {
            bindings = <
                &trans &trans &trans
            >;
            sensor-bindings = <&mouse_scroll SCRL_UP SCRL_DOWN>;
        };

        MouseSlow {
            bindings = <
                &trans &trans &trans
            >;
        };

        MouseFast {
            bindings = <
                &trans &trans &trans
            >;
        };

        MouseWarp {
            bindings = <
                &trans &trans &trans
            >;
        };

        EncoderHorizontal {
            bindings = <
                &trans &trans &trans
            >;
            sensor-bindings = <&mouse_scroll SCRL_LEFT SCRL_RIGHT>;
        };
    };
};
